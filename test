// ... 상단 import 부분 동일
const toggleInputButton = document.getElementById('toggle-input-button');
const historyPanel = document.getElementById('history-panel'); // 8. 설정/히스토리 패널용
const settingsButton = document.getElementById('settings-button'); // 8. 설정 버튼

// 2. 드래그 이동 로직 추가
let isDragging = false;
let mouseX, mouseY;

widget.addEventListener('mousedown', (e) => {
  if (e.target.closest('button') || e.target.closest('input')) return;
  isDragging = true;
  mouseX = e.clientX;
  mouseY = e.clientY;
});

window.addEventListener('mousemove', (e) => {
  if (isDragging) {
    ipcRenderer.send('window-drag', { mouseX, mouseY });
  }
});

window.addEventListener('mouseup', () => { isDragging = false; });

// 3, 8. 히스토리 및 설정 버튼 활성화
settingsButton.addEventListener('click', () => {
  const isHidden = historyPanel.classList.toggle('hidden');
  if (!isHidden) history.render(); // 3. 패널 열릴 때 히스토리 렌더링
});

// 6. 중단 버튼 클릭 시 상태 복구 로직 강화
function setInputMode(show) {
  const inputRow = document.getElementById('input-row');
  if (show) {
    if (speech.isRecording) {
      isAborted = true;
      speech.stop();
    }
    inputRow.classList.remove('hidden');
    toggleInputButton.innerText = '닫기';
  } else {
    inputRow.classList.add('hidden');
    toggleInputButton.innerText = '입력';
    toggleInputButton.style.backgroundColor = ''; // 색상 초기화
  }
}

// 7. 로딩 메시지 제어
async function startApp() {
  try {
    await tracker.init();
    const stream = await navigator.mediaDevices.getUserMedia({ video: true });
    video.srcObject = stream;
    video.onloadedmetadata = () => {
      video.play();
      isAppReady = true;
      statusText.innerText = "준비 완료"; // 7. 로딩 문구 제거
      ui.setReadiness(true); // 7. 준비 상태 업데이트
      loop();
    };
  } catch (err) { /* 에러 처리 */ }
}